# SUPREME Backend - production/homologation example
# Copy to .env.production and replace every CHANGE_ME value before starting.
# DATABASE_URL and REDIS_URL are overridden by docker-compose.production.yml.

ENVIRONMENT=production
ENABLE_DOCS=false
ENABLE_METRICS=true
LOG_LEVEL=INFO

# Used by service-level compose files and kept aligned with DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME_SUPREME_POSTGRES_HEX_32
REDIS_PASSWORD=CHANGE_ME_REDIS_HEX_32

DATABASE_URL=postgresql+asyncpg://supreme:CHANGE_ME_SUPREME_POSTGRES_HEX_32@supreme-db:5432/supreme
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://:CHANGE_ME_REDIS_HEX_32@supreme-redis:6379/0
RQ_QUEUE_ANALYTICS=analytics
RQ_QUEUE_EVENTS=events
RQ_QUEUE_DEAD_LETTER=dead_letter
RQ_MAX_RETRIES=3
RQ_RETRY_DELAY_S=60

API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=CHANGE_ME_64_BYTE_HEX_ADMIN_AND_METRICS_TOKEN
API_INGEST_TOKEN=CHANGE_ME_64_BYTE_HEX_INGEST_TOKEN
ALLOWED_ORIGINS=https://sentinela.example.org

# Keep SUPREME_SALT offline and out of backups, tickets, chat and git.
SUPREME_SALT=CHANGE_ME_64_BYTE_HEX_OFFLINE_SALT

# Unified analytics operational parameters. Do not change algorithm behavior without review.
STUDY_START_DATE=2026-01-01
WINDOW_DAYS=14
MIN_BASELINE_WINDOWS=4
MAX_BASELINE_WINDOWS=8
DQ_MIN_THRESHOLD=0.5
ALGORITHM_VERSION=SUPREME-ANALYTICS-1.0.0

# SENTINELA push integration.
SENTINELA_URL=https://sentinela.example.org
SENTINELA_API_KEY=CHANGE_ME_64_BYTE_HEX_SHARED_WITH_SENTINELA
