# SUPREME Backend - staging example
# Copy to a secure staging secret store or an untracked .env.staging file.
# Replace every CHANGE_ME value before starting staging services.

ENVIRONMENT=staging
ENABLE_DOCS=false
ENABLE_METRICS=true
LOG_LEVEL=INFO

POSTGRES_PASSWORD=CHANGE_ME_STAGING_SUPREME_POSTGRES_PASSWORD_64_CHARS
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD_64_CHARS

DATABASE_URL=postgresql+asyncpg://supreme:CHANGE_ME_STAGING_SUPREME_POSTGRES_PASSWORD_64_CHARS@supreme-db:5432/supreme
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://:CHANGE_ME_STAGING_REDIS_PASSWORD_64_CHARS@supreme-redis:6379/0
RQ_QUEUE_ANALYTICS=analytics
RQ_QUEUE_EVENTS=events
RQ_QUEUE_DEAD_LETTER=dead_letter
RQ_MAX_RETRIES=3
RQ_RETRY_DELAY_S=60

API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=CHANGE_ME_STAGING_API_SECRET_KEY_64_CHARS
API_INGEST_TOKEN=CHANGE_ME_STAGING_API_INGEST_TOKEN_64_CHARS
ALLOWED_ORIGINS=https://staging.example.org

SUPREME_SALT=CHANGE_ME_STAGING_SUPREME_SALT_64_CHARS

STUDY_START_DATE=2026-01-01
WINDOW_DAYS=14
MIN_BASELINE_WINDOWS=4
MAX_BASELINE_WINDOWS=8
DQ_MIN_THRESHOLD=0.5
ALGORITHM_VERSION=SUPREME-ANALYTICS-1.0.0

SENTINELA_URL=https://staging.example.org/sentinela
SENTINELA_API_KEY=CHANGE_ME_STAGING_SENTINELA_API_KEY_64_CHARS
