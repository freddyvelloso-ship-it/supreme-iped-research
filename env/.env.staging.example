# SUPREME V4 staging template. Copy to a secure secret store or untracked env file.
POSTGRES_PASSWORD=CHANGE_ME_STAGING_POSTGRES_PASSWORD_64_CHARS
SENTINELA_POSTGRES_PASSWORD=CHANGE_ME_STAGING_SENTINELA_POSTGRES_PASSWORD_64_CHARS
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD_64_CHARS
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STAGING_GRAFANA_PASSWORD_64_CHARS
SUPREME_API_WORKERS=2
SUPREME_WORKER_REPLICAS=2
GRAFANA_ROOT_URL=https://staging.example.org/grafana/
STAGING_GRAFANA_ROOT_URL=https://staging.example.org/grafana/
STAGING_ALERTMANAGER_URL=https://staging.example.org/alertmanager
ALERTMANAGER_SMTP_HOST=smtp.staging.example.org
ALERTMANAGER_SMTP_FROM=supreme-staging@example.org
ALERTMANAGER_EMAIL_TO=ops-staging@example.org
ALERTMANAGER_SMTP_REQUIRE_TLS=true
ALERTMANAGER_SMTP_PASSWORD=CHANGE_ME_STAGING_SMTP_PASSWORD
SUPREME_ENV_FILE=./supreme-backend/.env.staging.example
SENTINELA_ENV_FILE=./sentinela/.env.staging.example
API_INGEST_TOKEN=CHANGE_ME_STAGING_API_INGEST_TOKEN_64_CHARS
SUPREME_SALT=CHANGE_ME_STAGING_SUPREME_SALT_64_CHARS
SENTINELA_API_KEY=CHANGE_ME_STAGING_SENTINELA_API_KEY_64_CHARS
IPED_AUDIT_DIR=/secure/staging/iped-audit

