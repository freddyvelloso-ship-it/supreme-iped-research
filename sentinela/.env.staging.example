# SENTINELA - staging example
# Copy to a secure staging secret store or an untracked .env.staging file.
# Replace every CHANGE_ME value before starting staging services.

ENVIRONMENT=staging
ENABLE_DOCS=false
AUTO_INIT_DB=false

POSTGRES_PASSWORD=CHANGE_ME_STAGING_SENTINELA_POSTGRES_PASSWORD_64_CHARS
DATABASE_URL=postgresql+asyncpg://sentinela:CHANGE_ME_STAGING_SENTINELA_POSTGRES_PASSWORD_64_CHARS@sentinela-db:5432/sentinela

SECRET_KEY=CHANGE_ME_STAGING_JWT_SECRET_64_CHARS
SUPREME_API_KEY=CHANGE_ME_STAGING_SENTINELA_API_KEY_64_CHARS
BOOTSTRAP_TOKEN=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALLOWED_ORIGINS=https://staging.example.org
