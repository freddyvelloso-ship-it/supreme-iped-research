# SUPREME V4 - safe root environment template
# Copy this file to .env only in your local/deploy environment.
# Never commit .env, real tokens, salts, certificates, database dumps or IPED case data.

# Profile
ENV_PROFILE=production

# Datastores
POSTGRES_PASSWORD=CHANGE_ME_SUPREME_POSTGRES_HEX_32
SENTINELA_POSTGRES_PASSWORD=CHANGE_ME_SENTINELA_POSTGRES_HEX_32
REDIS_PASSWORD=CHANGE_ME_REDIS_HEX_32

# SUPREME API secrets
API_INGEST_TOKEN=CHANGE_ME_64_BYTE_HEX_INGEST_TOKEN
SUPREME_SALT=CHANGE_ME_64_BYTE_HEX_OFFLINE_SALT

# IPED integration
IPED_AUDIT_DIR=C:/Users/CHANGE_ME_USERNAME

# Runtime sizing
SUPREME_API_WORKERS=2
SUPREME_WORKER_REPLICAS=2

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_HEX_32
GRAFANA_ROOT_URL=https://sentinela.example.org/grafana/

# Backup
BACKUP_PASSPHRASE=CHANGE_ME_LONG_BACKUP_PASSPHRASE

# Alertmanager email
ALERTMANAGER_SMTP_FROM=SUPREME Alerts <alerts@example.org>
ALERTMANAGER_SMTP_HOST=smtp.example.org:587
ALERTMANAGER_SMTP_USERNAME=alerts@example.org
ALERTMANAGER_SMTP_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD
ALERTMANAGER_SMTP_REQUIRE_TLS=true
ALERTMANAGER_EMAIL_TO=operacao@example.org
